# StockIQ Environment Variables
# Copy this file to .env and fill in your values

# API Keys (optional - app works with mock data without these)
REACT_APP_ALPHA_VANTAGE_KEY=your_alpha_vantage_api_key_here
REACT_APP_FINNHUB_KEY=your_finnhub_api_key_here
REACT_APP_NEWS_API_KEY=your_newsapi_org_key_here

# Firebase (optional - for cloud auth & data persistence)
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id

# App Config
REACT_APP_NAME=StockIQ
REACT_APP_ENV=development
